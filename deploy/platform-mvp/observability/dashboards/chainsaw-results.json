{
  "title": "Chainsaw Test Results",
  "uid": "chainsaw-results",
  "tags": ["platform-mvp", "testing"],
  "timezone": "browser",
  "refresh": "1m",
  "panels": [
    {
      "id": 1, "title": "Last Test Result",
      "type": "stat", "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3},
      "targets": [{
        "expr": "{job=\"chainsaw-runner\"} | json | line_format \"{{.result}}\"",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "value": "pass", "text": "PASS"}, {"type": "value", "value": "fail", "text": "FAIL"}],
          "noValue": "WAIT",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    },
    {
      "id": 2, "title": "Last Run Duration",
      "type": "stat", "gridPos": {"x": 4, "y": 0, "w": 4, "h": 3},
      "targets": [{
        "expr": "{job=\"chainsaw-runner\"} | json duration_ms=\"duration_ms\" | unwrap duration_ms | __error__=\"\"",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"]}}
    },
    {
      "id": 3, "title": "Pass Rate (1h)",
      "type": "gauge", "gridPos": {"x": 8, "y": 0, "w": 4, "h": 3},
      "targets": [{
        "expr": "sum(count_over_time({job=\"chainsaw-runner\"} | json | result=\"pass\" [1h])) / sum(count_over_time({job=\"chainsaw-runner\"} | json [1h]))",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.8}, {"color": "green", "value": 0.95}]}
        }
      }
    },
    {
      "id": 4, "title": "Test Run History",
      "type": "table", "gridPos": {"x": 0, "y": 3, "w": 12, "h": 6},
      "targets": [{
        "expr": "{job=\"chainsaw-runner\"} | json | line_format \"{{.result}} {{.duration_ms}}ms\"",
        "refId": "A"
      }],
      "transformations": [
        {"id": "extractFields", "options": {"source": "Line", "format": "kvp"}}
      ]
    },
    {
      "id": 5, "title": "Test Duration Trend",
      "type": "timeseries", "gridPos": {"x": 0, "y": 9, "w": 12, "h": 5},
      "targets": [{
        "expr": "{job=\"chainsaw-runner\"} | json duration_ms=\"duration_ms\" | unwrap duration_ms | __error__=\"\"",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    }
  ],
  "schemaVersion": 39
}