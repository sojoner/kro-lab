{
  "title": "Token Rotation",
  "uid": "token-rotation",
  "tags": [
    "platform-mvp",
    "auth",
    "security"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Rotations per Region (5m rate)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rate(token_rotator_rotations_total{result=\"success\"}[5m])",
          "refId": "A",
          "legendFormat": "{{region}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 30
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Last Rotation Age (seconds)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "time() - token_rotator_last_rotation_timestamp_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Rotation Errors (5m rate)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "rate(token_rotator_rotation_errors_total[5m])",
          "refId": "A",
          "legendFormat": "{{region}}/{{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 30
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Rotation Debug Logs",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 16,
        "h": 6
      },
      "targets": [
        {
          "expr": "{app=\"token-rotator\"} |~ \"(?i)(rotation|token|renew|kubeconfig)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 5,
      "title": "Rotation Status per Region",
      "type": "table",
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "token_rotator_last_rotation_timestamp_seconds",
          "refId": "A",
          "format": "table"
        },
        {
          "expr": "time() - token_rotator_last_rotation_timestamp_seconds",
          "refId": "B",
          "format": "table"
        },
        {
          "expr": "rate(token_rotator_rotations_total{result=\"error\"}[5m])",
          "refId": "C",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "le": true
            }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39
}