{
  "title": "Controller & Rook Reconciliation",
  "uid": "controller-rook-recon",
  "tags": [
    "platform-mvp",
    "controller",
    "rook"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Reconcile Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "rate(controller_runtime_reconcile_total{controller=\"regionalbucket\"}[5m])",
          "refId": "A",
          "legendFormat": "total/s"
        },
        {
          "expr": "rate(controller_runtime_reconcile_total{controller=\"regionalbucket\",result=\"success\"}[5m])",
          "refId": "B",
          "legendFormat": "success/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Reconcile Errors",
      "type": "timeseries",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "rate(controller_runtime_reconcile_errors_total{controller=\"regionalbucket\"}[5m])",
          "refId": "A",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Reconcile Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(controller_runtime_reconcile_time_seconds_bucket{controller=\"regionalbucket\"}[5m]))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(controller_runtime_reconcile_time_seconds_bucket{controller=\"regionalbucket\"}[5m]))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(controller_runtime_reconcile_time_seconds_bucket{controller=\"regionalbucket\"}[5m]))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 4,
      "title": "Queue Depth",
      "type": "gauge",
      "gridPos": {
        "x": 6,
        "y": 4,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "expr": "controller_runtime_active_workers{controller=\"regionalbucket\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Success Rate",
      "type": "gauge",
      "gridPos": {
        "x": 9,
        "y": 4,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(controller_runtime_reconcile_total{controller=\"regionalbucket\",result=\"success\"}[5m])) / sum(rate(controller_runtime_reconcile_total{controller=\"regionalbucket\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Ceph OSDs Up/In",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(ceph_osd_up == 1 and ceph_osd_in == 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 3
              }
            ]
          },
          "mappings": [],
          "noValue": "0"
        }
      }
    },
    {
      "id": 11,
      "title": "Ceph Health Summary",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 8,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "ceph_health_status",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "value": "0",
              "text": "OK"
            },
            {
              "type": "value",
              "value": "1",
              "text": "WARN"
            },
            {
              "type": "value",
              "value": "2",
              "text": "ERR"
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "PG State",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "ceph_pg_active / ceph_pg_total * 100",
          "refId": "A",
          "legendFormat": "active+clean %"
        },
        {
          "expr": "ceph_pg_degraded / ceph_pg_total * 100",
          "refId": "B",
          "legendFormat": "degraded %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 13,
      "title": "RGW Requests/s",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "rate(ceph_rgw_req[5m])",
          "refId": "A",
          "legendFormat": "{{operation}}"
        }
      ]
    }
  ],
  "schemaVersion": 39
}