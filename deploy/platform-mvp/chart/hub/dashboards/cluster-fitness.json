{
  "title": "Cluster Fitness",
  "uid": "cluster-fitness",
  "tags": [
    "platform-mvp",
    "infrastructure"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Nodes Ready \u2014 hub",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [],
          "noValue": "0"
        }
      }
    },
    {
      "id": 2,
      "title": "Nodes Ready \u2014 us",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 4
              }
            ]
          },
          "mappings": [],
          "noValue": "0"
        }
      }
    },
    {
      "id": 3,
      "title": "Pods Not Running",
      "type": "table",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase!=\"Running\",phase!=\"Succeeded\"}) by (namespace,phase)",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Usage per Node",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 5,
      "title": "Memory Available %",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "(node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 6,
      "title": "API Server Availability",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 4,
        "h": 3
      },
      "targets": [
        {
          "expr": "up{job=\"apiserver\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "value": "1",
              "text": "UP"
            },
            {
              "type": "value",
              "value": "0",
              "text": "DOWN"
            }
          ]
        }
      }
    },
    {
      "id": 7,
      "title": "Persistent Volumes Status",
      "type": "table",
      "gridPos": {
        "x": 4,
        "y": 7,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "kube_persistentvolume_status_phase",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 39
}