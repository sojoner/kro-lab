{
  "title": "Chainsaw Test Results",
  "uid": "chainsaw-results",
  "tags": ["platform-mvp", "testing"],
  "timezone": "browser",
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "Last Test Result",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "{job=\"chainsaw-runner\"} | json",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json"
          }
        },
        {
          "id": "reduce",
          "options": {
            "reducers": ["lastNotNull"]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "value": "pass", "text": "PASS" },
            { "type": "value", "value": "fail", "text": "FAIL" }
          ],
          "noValue": "WAIT",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": "pass" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" }
    },
    {
      "id": 2,
      "title": "Last Run Duration",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "{job=\"chainsaw-runner\"} | json",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json"
          }
        },
        {
          "id": "reduce",
          "options": {
            "reducers": ["lastNotNull"],
            "includeTimeField": false
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" }
    },
    {
      "id": 3,
      "title": "Pass Rate (1h)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"chainsaw-runner\"} | json | result=~\"pass\" [1h])) / sum(count_over_time({job=\"chainsaw-runner\"} | json | result=~\".+\" [1h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "noValue": "NO DATA",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" }
    },
    {
      "id": 4,
      "title": "Test Run History",
      "type": "table",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "{job=\"chainsaw-runner\"} | json",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "tsNs": true,
              "id": true,
              "detected_level": true,
              "test_run": true,
              "report": true,
              "report_error": true,
              "service_name": true
            },
            "renameByName": {
              "Time": "Time",
              "duration_ms": "Duration (ms)",
              "result": "Result",
              "report.error": "Error"
            }
          }
        }
      ],
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" }
    },
    {
      "id": 5,
      "title": "Test Duration Trend",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 5 },
      "targets": [
        {
          "expr": "{job=\"chainsaw-runner\"} | json",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "tsNs": true,
              "id": true,
              "detected_level": true,
              "test_run": true,
              "report": true,
              "report_error": true,
              "service_name": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" }
    }
  ],
  "schemaVersion": 39
}